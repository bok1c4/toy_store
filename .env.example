# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=toystore_user
DB_PASSWORD=<generate with: openssl rand -hex 24>
DB_NAME=toystore

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<generate with: openssl rand -hex 24>

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 64 random characters
JWT_SECRET=<generate with: openssl rand -hex 32>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ─── External toy catalogue API ──────────────────────────────────────────────
EXTERNAL_API_URL=https://toy.pequla.com/api

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Server-side secret key (backend only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # optional — only needed for webhook signature verification

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Must start with NEXT_PUBLIC_ to be exposed to the browser
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-side fetch from Server Components → Go backend.
# Defaults to the Docker-network service name. Override only when running
# `npm run dev` outside Docker (e.g. INTERNAL_API_URL=http://localhost:8080).
INTERNAL_API_URL=http://backend:8080

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug
